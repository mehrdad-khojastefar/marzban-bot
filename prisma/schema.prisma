generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  paid
  test
}

enum PaymentStatus {
  pending
  awaiting_approval
  approved
  rejected
  cancelled
}

enum AccountPaymentStatus {
  unpaid
  paid
}

enum SellerPlanType {
  fixed
  per_unit
}

model User {
  id         Int       @id @default(autoincrement())
  chat_id    BigInt    @unique
  username   String?
  first_name String
  last_name  String?
  has_test   Boolean   @default(false)
  created_at DateTime  @default(now())
  accounts   Account[]
  payments   Payment[]
  seller     Seller?

  @@map("users")
}

model Plan {
  id            Int       @id @default(autoincrement())
  name          String
  data_limit    BigInt
  duration_days Int
  price         Int
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  accounts      Account[]
  payments      Payment[]

  @@map("plans")
}

model Account {
  id               Int                   @id @default(autoincrement())
  user_id          Int
  plan_id          Int?
  seller_id        Int?
  seller_plan_id   Int?
  marzban_username String
  type             AccountType
  payment_status   AccountPaymentStatus?
  price            Int?
  note             String?
  expires_at       DateTime
  created_at       DateTime              @default(now())
  user             User                  @relation(fields: [user_id], references: [id])
  plan             Plan?                 @relation(fields: [plan_id], references: [id])
  seller           Seller?               @relation(fields: [seller_id], references: [id])
  seller_plan      SellerPlan?           @relation(fields: [seller_plan_id], references: [id])

  @@map("accounts")
}

model Payment {
  id              Int           @id @default(autoincrement())
  user_id         Int
  plan_id         Int
  amount          Int
  status          PaymentStatus @default(pending)
  receipt_file_id String?
  reviewed_by     BigInt?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  user            User          @relation(fields: [user_id], references: [id])
  plan            Plan          @relation(fields: [plan_id], references: [id])

  @@map("payments")
}

model BotMessage {
  id         Int      @id @default(autoincrement())
  key        String   @unique @db.VarChar(100)
  text       String
  updated_at DateTime @updatedAt

  @@map("bot_messages")
}

model Seller {
  id          Int          @id @default(autoincrement())
  chat_id     BigInt       @unique
  user_id     Int?         @unique
  note        String?
  link_prefix String?
  is_active   Boolean      @default(true)
  created_at DateTime     @default(now())
  user       User?        @relation(fields: [user_id], references: [id])
  plans      SellerPlan[]
  accounts   Account[]

  @@map("sellers")
}

model SellerPlan {
  id         Int            @id @default(autoincrement())
  seller_id  Int
  name       String
  type       SellerPlanType @default(fixed)
  data_limit BigInt
  price      Int
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  seller     Seller    @relation(fields: [seller_id], references: [id])
  accounts   Account[]

  @@map("seller_plans")
}

model BotSetting {
  key        String   @id @db.VarChar(100)
  value      String
  updated_at DateTime @updatedAt

  @@map("bot_settings")
}

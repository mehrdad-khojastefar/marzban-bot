generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  paid
  test
}

enum PaymentStatus {
  pending
  awaiting_approval
  approved
  rejected
  cancelled
}

enum AccountPaymentStatus {
  unpaid
  paid
}

enum SellerPlanType {
  fixed
  per_unit
}

enum PlanGroupType {
  per_gb
  fixed
}

enum TransactionStatus {
  pending
  checkout
  awaiting_receipt
  awaiting_approval
  paid
  provisioning
  completed
  failed
  rejected
  cancelled
  expired
}

enum PaymentMethod {
  premzy
  manual
}

model PlanGroup {
  id            Int           @id @default(autoincrement())
  code          String        @unique @db.VarChar(8)
  name          String
  type          PlanGroupType
  price_per_gb  Int?
  duration_days Int           @default(30)
  is_active     Boolean       @default(true)
  created_at    DateTime      @default(now())
  users         User[]
  plans         Plan[]

  @@map("plan_groups")
}

model BankCard {
  id          Int       @id @default(autoincrement())
  card_number String
  holder_name String
  bank_name   String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  users        User[]
  payments     Payment[]
  transactions Transaction[]

  @@map("bank_cards")
}

model User {
  id            Int        @id @default(autoincrement())
  chat_id       BigInt     @unique
  username      String?
  first_name    String
  last_name     String?
  has_test      Boolean    @default(false)
  bank_card_id  Int?
  plan_group_id Int?
  created_at    DateTime   @default(now())
  accounts      Account[]
  payments      Payment[]
  transactions  Transaction[]
  seller        Seller?
  bank_card     BankCard?  @relation(fields: [bank_card_id], references: [id])
  plan_group    PlanGroup? @relation(fields: [plan_group_id], references: [id])

  @@map("users")
}

model Plan {
  id            Int        @id @default(autoincrement())
  group_id      Int?
  name          String
  data_limit    BigInt
  duration_days Int
  price         Int
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now())
  group         PlanGroup? @relation(fields: [group_id], references: [id])
  accounts      Account[]
  payments      Payment[]
  transactions  Transaction[]

  @@map("plans")
}

model Account {
  id                Int                   @id @default(autoincrement())
  user_id           Int
  plan_id           Int?
  seller_id         Int?
  seller_plan_id    Int?
  marzban_username  String
  marzban_sub_token String?
  display_name      String?
  type              AccountType
  payment_status    AccountPaymentStatus?
  price             Int?
  note              String?
  expires_at        DateTime
  created_at        DateTime              @default(now())
  user              User                  @relation(fields: [user_id], references: [id])
  plan              Plan?                 @relation(fields: [plan_id], references: [id])
  seller            Seller?               @relation(fields: [seller_id], references: [id])
  seller_plan       SellerPlan?           @relation(fields: [seller_plan_id], references: [id])
  transaction       Transaction?

  @@map("accounts")
}

model Payment {
  id              Int           @id @default(autoincrement())
  user_id         Int
  plan_id         Int?
  bank_card_id    Int?
  amount          Int
  data_limit      BigInt?
  status          PaymentStatus @default(pending)
  receipt_file_id String?
  reviewed_by     BigInt?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  user            User          @relation(fields: [user_id], references: [id])
  plan            Plan?         @relation(fields: [plan_id], references: [id])
  bank_card       BankCard?     @relation(fields: [bank_card_id], references: [id])

  @@map("payments")
}

model Transaction {
  id                Int               @id @default(autoincrement())
  transaction_id    String            @unique @default(uuid()) @db.Uuid
  user_id           Int
  plan_id           Int?
  data_limit        BigInt?
  duration_days     Int
  amount            Int
  status            TransactionStatus @default(pending)
  method            PaymentMethod
  premzy_order_id   String?           @unique
  bank_card_id      Int?
  receipt_file_id   String?
  reviewed_by       BigInt?
  account_id        Int?              @unique
  error_message     String?
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  user              User              @relation(fields: [user_id], references: [id])
  plan              Plan?             @relation(fields: [plan_id], references: [id])
  bank_card         BankCard?         @relation(fields: [bank_card_id], references: [id])
  account           Account?          @relation(fields: [account_id], references: [id])

  @@index([status])
  @@index([premzy_order_id])
  @@map("transactions")
}

model BotMessage {
  id         Int      @id @default(autoincrement())
  key        String   @unique @db.VarChar(100)
  text       String
  updated_at DateTime @updatedAt

  @@map("bot_messages")
}

model Seller {
  id         Int          @id @default(autoincrement())
  chat_id    BigInt       @unique
  user_id    Int?         @unique
  note       String?
  link_prefix String?
  is_active  Boolean      @default(true)
  created_at DateTime     @default(now())
  user       User?        @relation(fields: [user_id], references: [id])
  plans      SellerPlan[]
  accounts   Account[]

  @@map("sellers")
}

model SellerPlan {
  id         Int            @id @default(autoincrement())
  seller_id  Int
  name       String
  type       SellerPlanType @default(fixed)
  data_limit BigInt
  price      Int
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  seller     Seller    @relation(fields: [seller_id], references: [id])
  accounts   Account[]

  @@map("seller_plans")
}

model BotSetting {
  key        String   @id @db.VarChar(100)
  value      String
  updated_at DateTime @updatedAt

  @@map("bot_settings")
}

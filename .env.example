# Database
DATABASE_URL=postgresql://marzban_bot:marzban_bot@localhost:5432/marzban_bot

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=your_admin_telegram_chat_id

# Marzban Panel
MARZBAN_API_URL=https://your-marzban-panel.com
MARZBAN_USERNAME=your_marzban_admin_username
MARZBAN_PASSWORD=your_marzban_admin_password

# Bot Config
CARD_NUMBER=your_bank_card_number
SUPPORT_USERNAME=@your_support_username

# Proxy (optional)
# SOCKS5_PROXY=socks5://user:pass@host:port

# App
NODE_ENV=development

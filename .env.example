# Database
DATABASE_URL=postgresql://marzban_bot:marzban_bot@localhost:5432/marzban_bot

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=your_admin_telegram_chat_id

# Marzban Panel
MARZBAN_API_URL=https://your-marzban-panel.com
MARZBAN_USERNAME=your_marzban_admin_username
MARZBAN_PASSWORD=your_marzban_admin_password

# Subscription Proxy
SUB_BASE_URL=https://sub.mydoves.info:8085
MARZBAN_SUB_URL=http://internal-marzban-sub:8085
SUB_PORT=8085
CONFIG_LINK_PREFIX=🕊️ 🇩🇪  DE|

# Bot Config
SUPPORT_USERNAME=@your_support_username
CHANNEL_ID=-100XXXXXXXXXX                        # Optional if channel_check_enabled = false
CHANNEL_INVITE_LINK=https://t.me/+your_invite_hash  # Optional if channel_check_enabled = false

# Proxy (optional)
# SOCKS5_PROXY=socks5://user:pass@host:port

# App
NODE_ENV=development

PREMZY_VENDOR_ID=your-vendor-uuid
PREMZY_VENDOR_TOKEN=your-callback-auth-token
PREMZY_EC_PRIVATE_KEY_PATH=./keys/private.pem
PREMZY_CALLBACK_PORT=8086